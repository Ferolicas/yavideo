# ── App ───────────────────────────────────────────────
NODE_ENV=production
PORT=4001
APP_URL=https://yavideo.olcas.app

# ── Auth.js v5 (NextAuth) ─────────────────────────────
# Genera con: openssl rand -hex 32
AUTH_SECRET=
AUTH_URL=https://yavideo.olcas.app
AUTH_TRUST_HOST=true
# Google OAuth (https://console.cloud.google.com → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Base de datos (PostgreSQL en el VPS) ──────────────
DATABASE_URL=postgresql://user:password@localhost:5432/yavideo_db

# ── Cola / Redis (local en el VPS) ────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Email transaccional (Resend) ──────────────────────
# Magic link de login + avisos "tu vídeo está listo"
RESEND_API_KEY=
EMAIL_FROM="yavideo <no-reply@olcas.app>"

# ── Almacenamiento de vídeo (Cloudflare R2) ───────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=yavideo
# Dominio público opcional para assets públicos (miniaturas). Vacío = solo links firmados.
R2_PUBLIC_BASE_URL=
# Endpoint S3 de R2. Vacío = se deriva de R2_ACCOUNT_ID (jurisdicción por defecto).
# Para buckets en jurisdicción UE: https://<account>.eu.r2.cloudflarestorage.com
R2_S3_ENDPOINT=

# ── Pagos: Stripe (mundo) ─────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (recurring, EUR) creados en Stripe
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_BUSINESS=

# ── Pagos: Mercado Pago (Colombia) ────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
# Opcional: secreto de firma de webhooks (panel MP → Webhooks)
MERCADOPAGO_WEBHOOK_SECRET=

# ── CRM (HubSpot) — opcional ──────────────────────────
HUBSPOT_ACCESS_TOKEN=

# ── Entrega por WhatsApp (Evolution API) — opcional ───
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
